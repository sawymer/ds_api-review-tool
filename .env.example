# DS API Review Tool - Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# Path Overrides (Optional)
# =============================================================================
# Override default paths if your projects are in different locations

# Path to Laravel routes file
# Default: ~/dev/rf-api/routes/api/v1.php
# ROUTES_PATH=/path/to/routes/api/v1.php

# Path to OpenAPI spec (generate with: sail artisan l5-swagger:generate)
# Default: ~/dev/rf-api/storage/api-docs/api-docs.json
# OPENAPI_PATH=/path/to/api-docs.json

# Path to Angular developer settings component
# Default: ~/dev/rf-ui/src/app/client-layout/settings/developer-settings/developer-settings.component.ts
# UI_CONFIG_PATH=/path/to/developer-settings.component.ts

# Output directory for reports
# Default: ~/dev/AI_prod_notes/rf-api/api-catalog/
# OUTPUT_PATH=/path/to/output/

# =============================================================================
# Phase 2: Live Testing (Future)
# =============================================================================
# These will be used when live API testing is implemented

# DoorSpot API Base URL
# DS_API_URL=https://api.doorspot.com/v1

# API Key for authentication (Bearer token)
# DS_API_KEY=your_api_key_here

# Test mode (dry-run, sandbox, production)
# DS_TEST_MODE=dry-run
